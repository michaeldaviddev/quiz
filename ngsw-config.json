{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**/*",
          "/*.(svg|ico|png|webp)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "questions-json",
      "urls": ["/assets/questions.json"],
      "cacheConfig": {
        "maxSize": 1,
        "maxAge": "365d",
        "strategy": "performance"
      }
    }
  ]
}
